# URL(s) do frontend permitidas no CORS.
# No Railway, defina com o dominio do Cloudflare Pages (ou outro host).
# Multiplos origens devem ser separados por virgula.
# Ex: https://site-arteafeto.pages.dev,https://arteafeto.com.br
FRONTEND_URL=http://localhost:5500

# Porta do servidor (Railway define automaticamente via variavel PORT)
PORT=3000

# (Opcional) URL da API externa de produtos Xano
# Se nao definida, o backend usa o catalogo local embutido
PRODUTOS_API_URL=

# (Opcional) Chave da API externa de produtos
API_KEY=

# (Opcional) URLs da API Xano para pedidos e autenticacao
# Se nao definidas, as URLs padrao hardcoded no apiService.js serao usadas
XANO_ORDER_POST_URL=https://x8ki-letl-twmt.n7.xano.io/api:i2tKJnG4/orders_post
XANO_ORDER_LIST_URL=https://x8ki-letl-twmt.n7.xano.io/api:i2tKJnG4/orders
XANO_LOGIN_URL=https://x8ki-letl-twmt.n7.xano.io/api:_unQI8OU/auth/login
XANO_ME_URL=https://x8ki-letl-twmt.n7.xano.io/api:_unQI8OU/auth/me
